# NeuroMap — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais

# Chave da API Gemini (obtenha em https://aistudio.google.com/)
GOOGLE_AI_KEY=sua_chave_gemini_aqui

# Chave da API DeepSeek (Opcional - https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sua_chave_aqui

# URL da sua API instalada na Vercel
NEUROMAP_API_URL=https://neuromaplira.vercel.app/api/analyze
